# Copy this file to .env and fill in the required values.
# docker-compose.yml reads from here automatically.

# --- Required ---
PLEX_SECTION=Anime|Anime Movies
PLEX_URL=http://127.0.0.1:32400
PLEX_TOKEN=replace-with-your-plex-token
ANI_USERNAME=replace-with-your-anilist-username
ANI_TOKEN=replace-with-your-anilist-token

# --- Sync cadence (seconds between syncs; <= 0 means run once and exit) ---
INTERVAL=3600

# --- Optional behaviour toggles ---
# PLEX_EPISODE_COUNT_PRIORITY=False
# SKIP_LIST_UPDATE=False
# LOG_FAILED_MATCHES=False
# SYNC_RATINGS=False

# --- Optional cache tuning ---
# CACHE_DB_PATH=plexanisync_cache.db
# ANILIST_CACHE_TTL_HOURS=24
# CACHE_MAX_AGE_DAYS=14
# CACHE_SESSION_MARKER_PATH=/tmp/plexanisync_session
# BATCH_EPISODE_UPDATES=False

# --- Optional retry envelope ---
# MAX_RATE_LIMIT_RETRIES=8
# MAX_RATE_LIMIT_WAIT_SECONDS=300
# MAX_TRANSIENT_ERROR_RETRIES=10

# --- Optional webhook notifications ---
# Get a Discord webhook URL from Server Settings → Integrations → Webhooks.
# Slack: any incoming-webhook URL also works; set WEBHOOK_FORMAT=slack.
# WEBHOOK_URL=
# WEBHOOK_FORMAT=discord
# WEBHOOK_MIN_SEVERITY=error
